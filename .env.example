# Application Configuration
APP_NAME="AI Email Processing System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# API Configuration
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Database Configuration
DATABASE_URL=postgresql+asyncpg://email_user:secure_password@localhost:5432/email_processing_db
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# Authentication
SECRET_KEY=your-super-secret-key-change-in-production-with-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@example.com

# AI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-4
AI_REQUEST_TIMEOUT=30

# Microsoft Graph Configuration
MS_GRAPH_TENANT_ID=your-tenant-id
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_REFRESH_TOKEN=your-refresh-token
MS_GRAPH_SCOPES=https://graph.microsoft.com/.default

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Workers
WORKERS=4
